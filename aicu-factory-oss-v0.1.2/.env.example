# AICU Factory OSS
AICU_WORKSPACE=workspace
AICU_DB_PATH=workspace/jobs.db
AICU_MAX_RUN_PER_BATCH=3
AICU_BATCH_BUDGET=1.0
AICU_MAX_JOB_COST=0.5

# Optional Telegram notifier
AICU_TELEGRAM_ENABLED=false
AICU_TELEGRAM_BOT_TOKEN=
AICU_TELEGRAM_CHAT_ID=

# Optional manual telemetry endpoint placeholder
AICU_TELEMETRY_ENABLED=false
AICU_TELEMETRY_ENDPOINT=

# Z-Orchestrator
AICU_Z_PROJECTS_DIR=projects
